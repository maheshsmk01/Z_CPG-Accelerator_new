  [
   {
    "DDLNAME":"ZYCDS_DUE_MAT_LIST2",
    "AS4LOCAL":"N",
    "AS4USER":"SAP_CUSTOMER",
    "AS4DATE":"0000-00-00",
    "AS4TIME":"00:00:00",
    "SOURCE":"@AbapCatalog.viewEnhancementCategory: [#NONE]\r\n@AccessControl.authorizationCheck: #NOT_REQUIRED\r\n@EndUserText.label: 'Material Due Date List'\r\n@Metadata.ignorePropagatedAnnotations: true\r\n@ObjectModel.usageType:{\r\n    serviceQuality: #X, \r\n    sizeCategory: #S,\r\n    dataClass: #MIXED\r\n}\r\n@Metadata.allowExtensions: true\r\ndefine root view entity ZYCDS_DUE_MAT_LIST2 as select from ZYCDS_DUE_MAT_LIST\r\nassociation [1..1] to I_StorageLocation on I_StorageLocation.StorageLocation = ZYCDS_DUE_MAT_LIST.StorageLocation\r\n                                       and I_StorageLocation.Plant           = ZYCDS_DUE_MAT_LIST.Plant\r\n association [0..1] to zydc_config_cds_poc as _Config on ZYCDS_DUE_MAT_LIST.Remaining_days >= _Config.daysfrom  \r\n                               and ZYCDS_DUE_MAT_LIST.Remaining_days <= _Config.daysto                            \r\nassociation [0..1] to I_ProductStdVH  as _Mathelp on $projection.Material = _Mathelp.Product\r\nassociation [0..1] to ZYCDS_Batch_F4 as _Batchlp on $projection.Batch = _Batchlp.Batch\r\n\r\n{\r\n@Consumption.valueHelpDefinition: [\r\n  {\r\n    entity: {\r\n      name: 'I_ProductStdVH',\r\n      element: 'Product'\r\n    } \r\n  }\r\n]\r\n@ObjectModel.text.element: [ 'ProductDescription' ]\r\n  key ZYCDS_DUE_MAT_LIST.Material,\r\n  @Consumption.valueHelpDefinition: [\r\n  { entity: { name: 'I_PlantStdVH', element: 'Plant' } }\r\n]\r\n@ObjectModel.text.element: [ 'PlantName' ]\r\n  key ZYCDS_DUE_MAT_LIST.Plant,\r\n@Consumption.valueHelpDefinition: [\r\n  { entity: { name: 'I_StorageLocationStdVH', element: 'StorageLocation' } \r\n  }\r\n] \r\n@ObjectModel.text.element: [ 'StorageLocationName' ] \r\n  key ZYCDS_DUE_MAT_LIST.StorageLocation,\r\n \r\n  @Consumption.valueHelpDefinition: [\r\n  { entity: { name: 'ZYCDS_BATCH_F4', element: 'Batch' } } ]\r\n  key ZYCDS_DUE_MAT_LIST.Batch,\r\n  @ObjectModel.text.element: [ 'SupplierName' ]\r\n  key ZYCDS_DUE_MAT_LIST.Supplier,\r\n  ZYCDS_DUE_MAT_LIST.ProductDescription,\r\n  ZYCDS_DUE_MAT_LIST.PlantName,\r\n  I_StorageLocation.StorageLocationName,\r\n   @Consumption.valueHelpDefinition: [\r\n  { entity: { name: 'ZYCDS_SUPBatch_F4', element: 'BatchBySupplier' } \r\n  } ]\r\n  ZYCDS_DUE_MAT_LIST.BatchBySupplier,\r\n  ZYCDS_DUE_MAT_LIST.SupplierName,\r\n//  MatlWrhsStkQtyInMatlBaseUnit,\r\n @Consumption.valueHelpDefinition: [\r\n  { entity: { name: 'ZYCDS_UnResqty_F4', element: 'BaseUnit' } \r\n  } ]\r\n  ZYCDS_DUE_MAT_LIST.BaseUnit, \r\n  @Semantics.quantity.unitOfMeasure: 'BaseUnit'\r\n  MatlWrhsStkQtyInMatlBaseUnit,\r\n  MatlBatchIsInRstrcdUseStock,\r\n  @Semantics.quantity.unitOfMeasure: 'BaseUnit'\r\n  BlockedStockQty,\r\n  ZYCDS_DUE_MAT_LIST.ShelfLifeExpirationDate,\r\n  ZYCDS_DUE_MAT_LIST.ManufactureDate,\r\n  ZYCDS_DUE_MAT_LIST.BatchStatus,\r\n  ZYCDS_DUE_MAT_LIST.ShelfLifeExpirationDatePeriod, //N\r\n  ZYCDS_DUE_MAT_LIST.ShelfLifePeriodTypeText,  //N\r\n   ZYCDS_DUE_MAT_LIST.TotalShelfLife,     //N\r\n//  * --- NEW CONCATENATED FIELD --- */\r\n  concat_with_space( cast( ZYCDS_DUE_MAT_LIST.TotalShelfLife as abap.char(10) ),  //N\r\n                     ZYCDS_DUE_MAT_LIST.ShelfLifePeriodTypeText, 1 ) as TotalShelfLifeWithUnit, \r\n  Remaining_days, \r\n   ZYCDS_DUE_MAT_LIST.ShelfLifePercentage,                          //N\r\n     _Config.criticality as Criticality,\r\n  _Config.remarks as Due_range,\r\n  _Mathelp\r\n    \r\n    \r\n//     cast( '0' as abap.int1 ) as Criticality\r\n}  where _Config.remarks != '0'\r\n/*+[internal] {\n\"BASEINFO\":\n{\n\"FROM\":\n[\n\"I_STORAGELOCATION\",\n\"ZYCDS_DUE_MAT_LIST\",\n\"ZYDC_CONFIG_CDS_POC\"\n],\n\"ASSOCIATED\":\n[\n\"I_PRODUCTSTDVH\"\n],\n\"BASE\":\n[],\n\"ANNO_REF\":\n[],\n\"SCALAR_FUNCTION\":\n[],\n\"VERSION\":0,\n\"ANNOREF_EVALUATION_ERROR\":\"\"\n}\n}*/",
    "PARENTNAME":"",
    "ACTFLAG":"",
    "CHGFLAG":"54",
    "SOURCE_TYPE":"W",
    "SOURCE_ORIGIN":"0",
    "ABAP_LANGUAGE_VERSION":"5"
   }
  ]
